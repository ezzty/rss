---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif; background: #fafafa; color: #333; line-height: 1.6; }
    .container { max-width: 800px; margin: 0 auto; padding: 20px; }
    
    header { padding: 30px 0 20px; border-bottom: 1px solid #eee; margin-bottom: 30px; }
    header h1 { font-size: 24px; font-weight: 600; }
    header p { color: #999; font-size: 14px; margin-top: 8px; }
    
    .date-group { margin-bottom: 40px; }
    .date-header { font-size: 14px; color: #666; font-weight: 600; padding: 8px 0; border-bottom: 2px solid #eee; margin-bottom: 16px; }
    
    .article { padding: 16px 0; border-bottom: 1px solid #f0f0f0; }
    .article:last-child { border-bottom: none; }
    .article h2 { font-size: 17px; font-weight: 500; margin-bottom: 6px; }
    .article h2 a { color: #333; text-decoration: none; }
    .article h2 a:hover { color: #007bff; }
    .article .meta { font-size: 13px; color: #999; margin-bottom: 8px; }
    .article .meta .feed { color: #666; font-weight: 500; }
    .article .desc { font-size: 14px; color: #666; line-height: 1.7; }
    .article .desc a { color: #007bff; }
    
    .empty { text-align: center; padding: 60px 0; color: #999; }
    .empty p { font-size: 16px; }
    
    footer { text-align: center; padding: 40px 0; color: #ccc; font-size: 13px; }
    
    @media (max-width: 600px) {
      .container { padding: 16px; }
      header h1 { font-size: 20px; }
      .article h2 { font-size: 15px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>📡 RSS 订阅</h1>
      <p><slot name="subtitle" /></p>
    </header>
    
    <main>
      <slot />
    </main>
    
    <footer>
      RSS Reader · 每日自动更新
    </footer>
  </div>
</body>
</html>
